{
  "name": "@dvvebond/core",
  "version": "0.2.14",
  "description": "A fork of @libpdf/core with enhanced React components, Azure Document Intelligence integration, text extraction with bounding boxes, and enterprise PDF viewing features",
  "keywords": [
    "azure-document-intelligence",
    "bounding-box",
    "digital-signature",
    "document",
    "esign",
    "generator",
    "ocr",
    "parser",
    "pdf",
    "pdf-viewer",
    "pkcs7",
    "react",
    "react-pdf",
    "signing",
    "text-extraction",
    "typescript",
    "viewport-management"
  ],
  "homepage": "https://github.com/dvvebond/core",
  "bugs": {
    "url": "https://github.com/dvvebond/core/issues"
  },
  "license": "MIT",
  "author": "dvvebond",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvvebond/core.git"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs",
      "default": "./dist/react.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "vitest bench",
    "bench:report": "bun run scripts/bench-report.ts",
    "build": "tsdown",
    "demo": "bun --hot demo/index.html",
    "demo:serve": "bunx serve demo",
    "demo2": "bun --hot demo2/index.html",
    "demo2:serve": "bunx serve demo2",
    "docs:build": "bun run --cwd apps/docs build",
    "docs:dev": "bun run --cwd apps/docs dev",
    "examples": "bun run examples/run-all.ts",
    "examples:quiet": "bun run examples/run-all.ts --quiet",
    "format": "oxfmt",
    "lint": "oxlint --type-aware && oxfmt --check",
    "lint:fix": "oxlint --type-aware --fix && oxfmt",
    "prepare": "echo skip-prepare",
    "prepublishOnly": "bun run build",
    "release": "./scripts/release.sh",
    "test": "bun --env-file=.env.local vitest",
    "test:coverage": "bun --env-file=.env.local vitest run --coverage",
    "test:run": "bun --env-file=.env.local vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "asn1js": "^3.0.7",
    "lru-cache": "^11.2.6",
    "pako": "^2.1.0",
    "pdfjs-dist": "^4.8.69",
    "pkijs": "^3.3.3"
  },
  "devDependencies": {
    "@cantoo/pdf-lib": "^2.6.1",
    "@google-cloud/kms": "^5.0.0",
    "@google-cloud/secret-manager": "^6.0.0",
    "@types/bun": "^1.3.5",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "4.0.16",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.18.4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@google-cloud/kms": "^5.0.0",
    "@google-cloud/secret-manager": "^6.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/kms": {
      "optional": true
    },
    "@google-cloud/secret-manager": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
